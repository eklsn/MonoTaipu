[sub_resource type="GDScript" id="GDScript_ba0ut"]
script/source = "extends Node2D
func _ready() -> void:
	var file = FileAccess.open(Global.gamepath + \"/skins/skin.txt\", FileAccess.READ)
	if file != null:
		var skin_name = file.get_as_text().strip_edges()
		print(skin_name)
		file.close()
		var texture_path = Global.gamepath + \"/skins/\" + skin_name + \"/\"
		var outtex = ImageTexture.create_from_image(Image.load_from_file(texture_path+\"stroke_10px_gray.png\"))
		for child in get_children():
			child.texture=outtex
"

