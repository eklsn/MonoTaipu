[sub_resource type="GDScript" id="GDScript_ymoak"]
script/source = "extends Node2D

@export var tile_texture: Texture2D:
	set(v): tile_texture=v; reset_tiles()
@export var spacing := Vector2.ZERO:
	set(v): spacing=v; update_tiles()
@export var sprite_scale := Vector2.ONE:
	set(v): sprite_scale=v; update_tiles()
@export var ladder_speed := 50.0
@export var ladder_pattern := [1,-1]
@export var cols := 10
@export var rows := 10

var tiles = {}
var tile_size = Vector2.ZERO
var tile_step = Vector2.ZERO
var time = 0.0

func _ready():
	reset_tiles()
	if not tile_texture: tile_texture=ImageTexture.create_from_image(Image.load_from_file(Skins.get_resource_path(\"stroke_10px_gray.png\")))

func _process(delta):
	time+=delta
	update_positions()

func reset_tiles():
	for t in tiles.values(): t.queue_free()
	tiles.clear()
	update_tiles()

func update_tiles():
	if not tile_texture: return
	tile_size=tile_texture.get_size()
	tile_step=tile_size*sprite_scale+spacing
	for x in range(-cols/2,cols/2+cols%2):
		for y in range(-rows/2,rows/2+rows%2):
			var k=Vector2i(x,y)
			if tiles.has(k): continue
			var s=Sprite2D.new()
			s.texture=tile_texture
			s.scale=sprite_scale
			s.set_meta(\"x\",x)
			s.set_meta(\"y\",y)
			add_child(s)
			tiles[k]=s

func update_positions():
	for s in tiles.values():
		var x=s.get_meta(\"x\")
		var y=s.get_meta(\"y\")
		var base=Vector2(x,y)*tile_step
		var dir=ladder_pattern[x%ladder_pattern.size()]
		var h=tile_step.y
		s.position=base+Vector2(0,fmod(time*ladder_speed*dir,h)-h)
		if s.scale!=sprite_scale: s.scale=sprite_scale
"

[sub_resource type="GDScript" id="GDScript_ssg7n"]
script/source = "extends Button

func _on_pressed() -> void:
	get_tree().current_scene.get_node(\"fade\").anim_fade(0.1)
	Global.picker_mode = \"editor\"
	await get_tree().create_timer(0.03).timeout
	get_tree().change_scene_to_file(\"res://scenes/levelselect.tscn\")
"

