[sub_resource type="GDScript" id="GDScript_uo6ex"]
script/source = "extends Button

func _on_pressed() -> void:
	var lvlmeta = {
				\"name\" : \"\",
				\"song_author\" : \"\",
				\"lvl_author\" : \"\",
				\"audiofile\" : \"\",
				\"videofile\" : \"\",
				\"imagefile\" : \"\",
				\"pre_ring_time\" : 0.2,
				\"ring_time\" : 0.5,
				\"hit_timeframe\" : 0.2,
				\"readscheme\" : 0,
				\"minus_hp_on_miss\" : 25,
				\"minus_hp_idle\" : 0.5,
				\"exportbuild\" : Global.build,
				\"znote\" : \"\"
			}
	var savekeys = []
	savekeys.insert(0,lvlmeta)
	savekeys = JSON.stringify(savekeys,\"\\t\")
	var path = await Global.save_var_with_dialog(savekeys)
	await get_tree().create_timer(0.03).timeout
	Global.KEYMAN_LEVEL = path
	print(path)
	get_tree().change_scene_to_file(\"res://scenes/editor.tscn\")
"

