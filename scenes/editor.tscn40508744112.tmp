[sub_resource type="GDScript" id="GDScript_ba0ut"]
script/source = "extends Node2D
func _ready() -> void:
	var file = FileAccess.open(Global.gamepath + \"/skins/skin.txt\", FileAccess.READ)
	if file != null:
		var skin_name = file.get_as_text().strip_edges()
		print(skin_name)
		file.close()
		var texture_path = Global.gamepath + \"/skins/\" + skin_name + \"/\"
		var outtex = ImageTexture.create_from_image(Image.load_from_file(texture_path+\"stroke_10px_gray.png\"))
		for child in get_children():
			child.texture=outtex
"

[sub_resource type="GDScript" id="GDScript_q68jb"]
script/source = "extends Control

@export var zoom := 100.0       # pixels per second
@export var offset := 0.0       # scroll offset
@export var key_width := 40.0
@export var key_height := 24.0
@export var key_spacing := 4.0
var dragging := false
var drag_start_x := 0.0
var drag_start_offset := 0.0

func _draw():
	# background
	draw_rect(Rect2(Vector2.ZERO, size), Color(0.12, 0.12, 0.12))

	# simple vertical bars for reference
	for i in range(int(offset), int(offset + size.x / zoom) + 1):
		var x := (i - offset) * zoom
		draw_line(Vector2(x, 0), Vector2(x, size.y), Color(0.6, 0.6, 0.6))

	# draw keys
	var editor = get_tree().current_scene
	if editor == null or not editor.has_variable(\"editkeys\"):
		return

	var stack = 0
	for k in editor.editkeys:
		if k == [0]:
			continue

		var t = k[editor.datapoints[\"timing\"]]
		var key_name = str(k[editor.datapoints[\"key\"]])
		var x = (t - offset) * zoom
		var y = stack * (key_height + key_spacing)

		# rectangle
		draw_rect(Rect2(Vector2(x - key_width*0.5, y), Vector2(key_width, key_height)), Color(0.9, 0.3, 0.3))

		# text inside rectangle
		draw_string(load(\"res://fonts/VarelaRound-Regular.ttf\"), Vector2(x - key_width*0.4, y + key_height*0.7), key_name, Color(1,1,1))

		stack += 1
		if y > size.y - key_height:
			stack = 0

func _gui_input(event):
	# drag timeline with middle mouse
	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_MIDDLE:
			dragging = event.pressed
			if dragging:
				drag_start_x = event.position.x
				drag_start_offset = offset

		if event.button_index == MOUSE_BUTTON_WHEEL_UP:
			zoom *= 1.1
		elif event.button_index == MOUSE_BUTTON_WHEEL_DOWN:
			zoom *= 0.9
		queue_redraw()

	if event is InputEventMouseMotion and dragging:
		offset = drag_start_offset + (event.position.x - drag_start_x) / zoom
		queue_redraw()

func _process(_delta):
	queue_redraw()
"

