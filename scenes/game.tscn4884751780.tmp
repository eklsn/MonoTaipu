[sub_resource type="GDScript" id="GDScript_lnu2h"]
script/source = "extends Label

var prevscore = 0
var score = 0
var sndcool = false
func _process(delta: float) -> void:
	text = str(score)+\"x\"
	scale=lerp(scale,Vector2(1,1),0.01)
	modulate = lerp(modulate,Color.WHITE,0.0025)
	if prevscore<score:
		scale = Vector2(1.3,1.3)
		prevscore=score
	if score==0 && prevscore!=0:
		var clsound = null
		clsound = null
		prevscore=0
		modulate = Color.RED
		if !sndcool:
			sndcool = true
			clsound = AudioStreamPlayer.new()
			clsound.name = \"lsound\"
			clsound.stream = load(\"res://sounds/miss-sound.mp3\")
			add_child(clsound)
			clsound.play()
			await get_tree().create_timer(3.0).timeout
			clsound.queue_free()
			clsound = null
			sndcool=false
	
"

[sub_resource type="GDScript" id="GDScript_lbhrr"]
script/source = "extends Node2D
func _ready() -> void:
	var file = FileAccess.open(Global.gamepath + \"/skins/skin.txt\", FileAccess.READ)
	if file != null:
		var skin_name = file.get_as_text().strip_edges()
		print(skin_name)
		file.close()
		var texture_path = Global.gamepath + \"/skins/\" + skin_name + \"/\"
		var outtex = ImageTexture.create_from_image(Image.load_from_file(texture_path+\"stroke_10px_gray.png\"))
		for child in get_children():
			child.texture=outtex
"

