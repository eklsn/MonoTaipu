offset_bottom = 888.0
theme_override_font_sizes/normal_font_size = 32
text = "F11 - Full Screen
SHIFT+ESC - Discard Changes and quit to Main Menu
SHIFT+F12 - Discard Changes and Load File

F1 - 1x speed
F2 - 0.5x speed
F3 - 0.25x speed
F4 - 2x speed

F9 - Hide Video (if scrolling feels laggy, video might be the case.)
F10 - Save

SHIFT+DEL - Erase all the keys and start anew (NO UNDO)

HOME - Rewind to the start of the level
Space - Pause/Play
Arrow left - Rewind
Arrow Right - Forward
(Mousewheel also works)

Any letter key visible on keyboard - create a hit at current time
Right Click - delete that key. 
"

